# Copy this file to .env and fill in values.
# .env is gitignored — never commit real credentials.

# Override the Ollama server URL (default: http://127.0.0.1:11434)
# OLLAMA_URL=http://127.0.0.1:11434

# Override the default model
# OLLAMA_MODEL=codestral

# Override the Outlook database path (macOS only)
# OUTLOOK_DB_PATH=/Users/yourname/Library/Group Containers/UBF8T346G9.Office/Outlook/Outlook 15 Profiles/Main Profile/Data
